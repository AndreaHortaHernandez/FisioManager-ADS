datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   // PATIENT | THERAPIST | ADMIN
  avatarUrl String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile        PatientProfile?
  routines              Routine[]
  feedbacks             Feedback[]
  patientAppointments   Appointment[] @relation("AppointmentPatient")
  therapistAppointments Appointment[] @relation("AppointmentTherapist")
}

model PatientProfile {
  userId      String @id
  age         Int
  condition   String
  therapistId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // PHYSICAL | BREATHING
  bodyPart    String?  // KNEE | BACK | SHOULDER | NECK | ARM | HIP | ANKLE | OTHER (solo para PHYSICAL)
  videoUrl    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model Routine {
  id           String    @id @default(cuid())
  patientId    String?   // null = template en la biblioteca
  title        String
  type         String    // TREATMENT | RELAXATION
  completed    Boolean   @default(false)
  assignedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient    User?      @relation(fields: [patientId], references: [id])
  activities Activity[]
  feedbacks  Feedback[]
}

model Activity {
  id              String  @id @default(cuid())
  routineId       String
  templateId      String?
  title           String
  description     String
  durationMinutes Int
  restSeconds     Int?
  repetitions     Int
  type            String  // PHYSICAL | BREATHING
  order           Int
  videoUrl        String?

  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model Feedback {
  id             String   @id @default(cuid())
  routineId      String
  patientId      String
  painLevel      Int
  emotionalState String   // GREAT | GOOD | OK | BAD | TERRIBLE
  audioRecordUrl String?
  aiSummary      String?
  date           DateTime @default(now())

  routine Routine @relation(fields: [routineId], references: [id])
  patient User    @relation(fields: [patientId], references: [id])
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  therapistId String
  dateTime    DateTime
  status      String   @default("SCHEDULED") // SCHEDULED | CANCELLED | COMPLETED
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  patient   User @relation("AppointmentPatient", fields: [patientId], references: [id])
  therapist User @relation("AppointmentTherapist", fields: [therapistId], references: [id])
}
