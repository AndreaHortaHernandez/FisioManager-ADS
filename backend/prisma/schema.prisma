datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String // PATIENT | THERAPIST | ADMIN
  isActive  Boolean  @default(true)
  emailVerified Boolean @default(true) // false solo para cuentas auto-registradas pendientes de verificar
  avatarUrl String?
  phone     String?
  audioConsentAt DateTime? // consentimiento informado para grabar/procesar audio con IA
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patientProfile        PatientProfile?
  therapistProfile      TherapistProfile?
  routines              Routine[]
  feedbacks             Feedback[]
  sessions              Session[]
  patientAppointments   Appointment[]           @relation("AppointmentPatient")
  therapistAppointments Appointment[]           @relation("AppointmentTherapist")
  patientAssignments    RoutineAssignment[]     @relation("AssignmentPatient")
  therapistAssignments  RoutineAssignment[]     @relation("AssignmentTherapist")
  clinicalHistory       ClinicalHistory?
  clinicalNotes         ClinicalNote[]          @relation("NoteAuthor")
  availability          TherapistAvailability[] @relation("TherapistAvailability")
  patientPlans          TreatmentPlan[]         @relation("PlanPatient")
  therapistPlans        TreatmentPlan[]         @relation("PlanTherapist")
  notificationPreference NotificationPreference?
  refreshTokens         RefreshToken[]
  notifications         Notification[]
}

model PatientProfile {
  userId      String @id
  age         Int
  condition   String
  therapistId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TherapistProfile {
  userId       String  @id
  cedula       String?
  especialidad String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityTemplate {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String // PHYSICAL | BREATHING
  bodyPart    String? // KNEE | BACK | SHOULDER | NECK | ARM | HIP | ANKLE | OTHER (solo para PHYSICAL)
  videoUrl    String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model Routine {
  id           String    @id @default(cuid())
  patientId    String? // null = template en la biblioteca
  title        String
  type         String // TREATMENT | RELAXATION
  completed    Boolean   @default(false)
  assignedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient     User?               @relation(fields: [patientId], references: [id])
  activities  Activity[]
  feedbacks   Feedback[]
  assignments RoutineAssignment[]
  sessions    Session[]
}

model RoutineAssignment {
  id            String    @id @default(cuid())
  routineId     String
  patientId     String
  therapistId   String
  phaseId       String? // fase del plan de tratamiento que prescribe esta asignación
  startDate     DateTime
  endDate       DateTime?
  frequency     String // DAILY | EVERY_OTHER_DAY | WEEKLY
  status        String    @default("ACTIVE") // ACTIVE | PAUSED | CANCELLED
  lastReminderAt DateTime? // último recordatorio de ejecución enviado al paciente
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  routine   Routine        @relation(fields: [routineId], references: [id])
  patient   User           @relation("AssignmentPatient", fields: [patientId], references: [id])
  therapist User           @relation("AssignmentTherapist", fields: [therapistId], references: [id])
  phase     TreatmentPhase? @relation(fields: [phaseId], references: [id])
}

model Activity {
  id              String  @id @default(cuid())
  routineId       String
  templateId      String?
  title           String
  description     String
  durationMinutes Int
  restSeconds     Int?
  repetitions     Int
  type            String // PHYSICAL | BREATHING
  order           Int
  videoUrl        String?

  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)
}

model Feedback {
  id             String   @id @default(cuid())
  routineId      String?
  patientId      String
  painLevel      Int
  emotionalState String // GREAT | GOOD | OK | BAD | TERRIBLE
  audioRecordUrl String?
  transcript     String?
  aiSummary      String?
  date           DateTime @default(now())

  routine Routine? @relation(fields: [routineId], references: [id])
  patient User     @relation(fields: [patientId], references: [id])
}

model Session {
  id             String    @id @default(cuid())
  routineId      String
  patientId      String
  status         String    @default("IN_PROGRESS") // IN_PROGRESS | FINISHED
  completionRate Float?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  routine   Routine           @relation(fields: [routineId], references: [id])
  patient   User              @relation(fields: [patientId], references: [id])
  exercises SessionExercise[]
}

model SessionExercise {
  id         String @id @default(cuid())
  sessionId  String
  activityId String
  order      Int
  status     String // COMPLETED | SKIPPED

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, activityId])
}

model Appointment {
  id              String   @id @default(cuid())
  patientId       String
  therapistId     String
  dateTime        DateTime
  status          String   @default("SCHEDULED") // SCHEDULED | CANCELLED | COMPLETED
  roomId          String? // sala asignada
  treatmentPlanId String? // plan de tratamiento asociado (contexto clínico de la consulta)
  notes           String?
  reminded24h     Boolean  @default(false)
  recurrenceGroupId String? // agrupa las instancias de una serie de citas recurrentes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient       User           @relation("AppointmentPatient", fields: [patientId], references: [id])
  therapist     User           @relation("AppointmentTherapist", fields: [therapistId], references: [id])
  room          Room?          @relation(fields: [roomId], references: [id])
  treatmentPlan TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id])
}

// ── Salas / consultorios ───────────────────────────────────────────────────
model Room {
  id          String   @id @default(cuid())
  name        String
  location    String?
  capacity    Int      @default(1)
  equipment   String? // lista separada por comas
  createdAt   DateTime @default(now())

  appointments Appointment[]
}

// ── Historial Clínico ──────────────────────────────────────────────────────
model ClinicalHistory {
  id         String   @id @default(cuid())
  patientId  String   @unique
  bloodType  String? // tipo de sangre
  allergies  String? // alergias
  background String? // antecedentes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient   User           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  diagnoses Diagnosis[]
  notes     ClinicalNote[]
}

model Diagnosis {
  id          String   @id @default(cuid())
  historyId   String
  cie10Code   String // código CIE-10
  description String
  status      String   @default("ACTIVE") // ACTIVE | RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  history ClinicalHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
}

model ClinicalNote {
  id        String   @id @default(cuid())
  historyId String
  authorId  String
  content   String
  isVisible Boolean  @default(false) // visible para el paciente
  createdAt DateTime @default(now())

  history ClinicalHistory @relation(fields: [historyId], references: [id], onDelete: Cascade)
  author  User            @relation("NoteAuthor", fields: [authorId], references: [id])
}

// ── Plan de Tratamiento ────────────────────────────────────────────────────
model TreatmentPlan {
  id           String    @id @default(cuid())
  patientId    String
  therapistId  String
  name         String
  clinicalGoal String?
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("ACTIVE") // ACTIVE | COMPLETED | SUSPENDED
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patient      User             @relation("PlanPatient", fields: [patientId], references: [id])
  therapist    User             @relation("PlanTherapist", fields: [therapistId], references: [id])
  phases       TreatmentPhase[]
  appointments Appointment[]
}

model TreatmentPhase {
  id            String   @id @default(cuid())
  planId        String
  name          String
  order         Int
  durationWeeks Int
  objectives    String?
  createdAt     DateTime @default(now())

  plan        TreatmentPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  assignments RoutineAssignment[]
}

// ── Preferencias de notificación ──────────────────────────────────────────
model NotificationPreference {
  id                   String  @id @default(cuid())
  userId               String  @unique
  emailEnabled         Boolean @default(true)
  routineReminders     Boolean @default(true)
  appointmentReminders Boolean @default(true)
  quietHoursStart      String? // "HH:MM"
  quietHoursEnd        String? // "HH:MM"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Disponibilidad del terapeuta (HorarioDisponible) ──────────────────────
model TherapistAvailability {
  id          String @id @default(cuid())
  therapistId String
  dayOfWeek   Int // 0=Dom ... 6=Sáb
  startTime   String // "09:00"
  endTime     String // "17:00"

  therapist User @relation("TherapistAvailability", fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, dayOfWeek])
}

// ── Tokens revocados (logout) ─────────────────────────────────────────────
model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── Refresh tokens (RNF-023: access token de 60 min + refresh de 7 días) ──
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Bitácora de auditoría (acciones sensibles: login, acceso a historial, etc.) ──
model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // null para acciones sin sesión (p. ej. intento de login fallido)
  action    String // LOGIN | LOGOUT | VIEW_CLINICAL_HISTORY | UPLOAD_DOCUMENT | ...
  entity    String // User | ClinicalHistory | Appointment | ...
  entityId  String?
  metadata  String? // JSON serializado con contexto adicional
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ── Mapa corporal de dolor (puntos marcados junto al feedback) ───────────────
model PainPoint {
  id         String   @id @default(cuid())
  feedbackId String?
  patientId  String
  bodyPart   String // KNEE | BACK | SHOULDER | NECK | ARM | HIP | ANKLE | OTHER
  side       String? // LEFT | RIGHT | CENTER
  intensity  Int // 1-10
  note       String?
  createdAt  DateTime @default(now())

  @@index([patientId])
  @@index([feedbackId])
}

// ── Escalas de resultado (ROM, fuerza, escalas funcionales, VAS) ─────────────
model OutcomeMeasure {
  id          String   @id @default(cuid())
  patientId   String
  therapistId String
  type        String // ROM | STRENGTH | FUNCTIONAL | VAS
  label       String? // p. ej. "Flexión de rodilla"
  value       Float
  unit        String? // grados, kg, %, etc.
  measuredAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([patientId, type])
}

// ── Documentos clínicos (radiografías, laboratorios, consentimientos, etc.) ──
model ClinicalDocument {
  id         String   @id @default(cuid())
  patientId  String
  uploaderId String
  fileName   String
  fileUrl    String
  mimeType   String
  sizeBytes  Int
  category   String   @default("OTHER") // XRAY | LAB | CONSENT | REPORT | OTHER
  isVisible  Boolean  @default(false) // visible para el paciente
  createdAt  DateTime @default(now())

  @@index([patientId])
}

// ── Lista de espera de citas ─────────────────────────────────────────────────
model Waitlist {
  id          String   @id @default(cuid())
  patientId   String
  therapistId String
  desiredFrom DateTime
  desiredTo   DateTime
  status      String   @default("WAITING") // WAITING | NOTIFIED | FULFILLED | CANCELLED
  createdAt   DateTime @default(now())

  @@index([therapistId, status])
  @@index([patientId])
}

// ── Mensajería paciente ↔ terapeuta ─────────────────────────────────────────
model Conversation {
  id            String   @id @default(cuid())
  patientId     String
  therapistId   String
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages Message[]

  @@unique([patientId, therapistId])
  @@index([patientId])
  @@index([therapistId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── Notificaciones in-app (centro de notificaciones / campana) ───────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // APPOINTMENT | ROUTINE | HIGH_PAIN | MESSAGE | SYSTEM
  title     String
  body      String
  linkUrl   String? // ruta del frontend a la que navega al hacer clic
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
