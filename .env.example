# Frontend (dev): URL del API. En Docker se usa /api (proxy nginx).
VITE_API_URL=http://localhost:3001/api

# ── Variables leídas por docker-compose.yml ───────────────────────────────
# Copia este archivo a `.env` (mismo directorio) y rellena los valores.
# El `.env` está en .gitignore: NO se sube al repositorio.
# Genera secretos fuertes con:  openssl rand -base64 48

# ── Base de datos (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_USER=fisio
POSTGRES_PASSWORD=cambia-esta-contraseña
POSTGRES_DB=fisiomanager

# Secreto para firmar los JWT. OBLIGATORIO en producción: ≥ 32 caracteres
# aleatorios (el backend se niega a arrancar con un valor inseguro si NODE_ENV=production).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# ── Dominio / URLs (producción) ────────────────────────────────────────────
# Deben apuntar al dominio público real del frontend.
CORS_ORIGIN=https://tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

# Solo para el override TLS (docker-compose.prod.yml con Caddy):
DOMAIN=tu-dominio.com
ACME_EMAIL=tu-correo@ejemplo.com

# Modelo de Ollama para la IA.
OLLAMA_MODEL=gemma4:e2b

# ── Observabilidad (opcional) ──────────────────────────────────────────────
# Define SENTRY_DSN para enviar errores a Sentry; vacío = solo logs locales.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ── Almacenamiento de archivos ─────────────────────────────────────────────
# 'local' = disco (volumen fisio-uploads). 's3' = MinIO/S3 (override de prod).
STORAGE_DRIVER=local
S3_ENDPOINT=http://minio:9000
S3_BUCKET=fisio-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=fisio
S3_SECRET_KEY=cambia-esta-clave-de-minio
# URL pública del bucket, accesible desde el navegador (dominio o IP:9000/bucket).
S3_PUBLIC_URL=

# ── Escalado horizontal de Socket.IO ───────────────────────────────────────
# Solo necesario si corres varias instancias del backend (el override de prod
# levanta Redis y define esto automáticamente).
REDIS_URL=

# ── Backups automáticos de la base de datos ────────────────────────────────
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ── SMTP real (Brevo) ─────────────────────────────────────────────────────
# Si EMAIL_HOST queda vacío, se usa una cuenta de prueba (no llega a correos reales).
# Credenciales en Brevo → SMTP & API → SMTP.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=login-que-muestra-brevo          # ej. 8a1b2c001@smtp-brevo.com
EMAIL_PASS=clave-smtp-de-brevo              # la "SMTP key" (NO la contraseña de tu cuenta)
# EMAIL_FROM debe ser un remitente VERIFICADO en Brevo (Senders & IP → Senders).
EMAIL_FROM=FisioManager <tu-correo-verificado@dominio.com>
