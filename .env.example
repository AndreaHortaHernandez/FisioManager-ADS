# Frontend (dev): URL del API. En Docker se usa /api (proxy nginx).
VITE_API_URL=http://localhost:3001/api

# ── Variables leídas por docker-compose.yml ───────────────────────────────
# Copia este archivo a `.env` (mismo directorio) y rellena los valores.
# El `.env` está en .gitignore: NO se sube al repositorio.

# Secreto para firmar los JWT (cámbialo por algo largo y aleatorio).
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Modelo de Ollama para la IA.
OLLAMA_MODEL=gemma4:e2b

# ── SMTP real (Brevo) ─────────────────────────────────────────────────────
# Si EMAIL_HOST queda vacío, se usa una cuenta de prueba Ethereal (no llega a correos reales).
# Credenciales en Brevo → SMTP & API → SMTP.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=login-que-muestra-brevo          # ej. 8a1b2c001@smtp-brevo.com
EMAIL_PASS=clave-smtp-de-brevo              # la "SMTP key" (NO la contraseña de tu cuenta)
# EMAIL_FROM debe ser un remitente VERIFICADO en Brevo (Senders & IP → Senders).
EMAIL_FROM=FisioManager <tu-correo-verificado@dominio.com>
